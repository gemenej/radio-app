{
  "servers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${workspaceFolder}/data",
        "${workspaceFolder}/apps",
        "${workspaceFolder}/services"
      ]
    },
    "ffmpeg-tools": {
      "command": "node",
      "args": ["${workspaceFolder}/tools/mcp-ffmpeg/index.js"],
      "env": {
        "AUDIO_DATA_PATH": "${workspaceFolder}/data"
      }
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"]
    }
  }
}
